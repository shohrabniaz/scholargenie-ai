# Supabase — create a free project at https://supabase.com
# Project Settings → API → URL + publishable key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy name still supported: NEXT_PUBLIC_SUPABASE_ANON_KEY
# Service role key — only for server/cron (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password for local migrations/seeds (Project Settings → Database)
SUPABASE_DB_PASSWORD=your-db-password

# Site URL for auth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — powers the AI advisor chat (optional; falls back to rules without it)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Resend — deadline reminder emails (https://resend.com)
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=ScholarGenie AI <reminders@yourdomain.com>

# Cron — protect /api/deadlines/remind?cron=1 (Vercel cron in vercel.json)
CRON_SECRET=generate-a-long-random-string
